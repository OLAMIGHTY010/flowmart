{
  "compilerOptions": {
    /* Language and Environment */
    "target": "es2020",                                  
    
    /* Modules */
    "module": "commonjs",                                
    "rootDir": "./",                                     
    "outDir": "./dist",                                  
    "esModuleInterop": true,                             
    "forceConsistentCasingInFileNames": true,            
    
    /* Type Checking */
    "strict": true,                                      
    "skipLibCheck": true,                                
    
    /* Global Types & Environment Fixes */
    "types": ["node", "jest"],                           
    "ignoreDeprecations": "6.0",                         
    "baseUrl": "./"
  },
  "include": [
    "src/**/*",
    "db/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}